---
import { Image } from "astro:assets";
import logoKazanova from "../assets/imagens/logo-kazanova.png";
import { empresa } from "@dados/empresa";
import { itensNavegacao } from "@dados/navegacao";
---

<header class="cabecalho">
  <div class="cabecalho__conteudo">
    <a class="cabecalho__marca" href="/" aria-label={`${empresa.nome} - página inicial`}>
      <Image
        src={logoKazanova}
        alt="Kazanova Sob Medida"
        width={246}
        height={82}
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="cabecalho__navegacao" aria-label="Navegação principal">
      {itensNavegacao.map((item) => <a href={item.href}>{item.texto}</a>)}
    </nav>

    <a class="cabecalho__cta" href={empresa.linkWhatsappOrcamento} target="_blank" rel="noopener noreferrer">
      Solicitar orçamento
    </a>

    <details class="cabecalho__menu-mobile">
      <summary aria-label="Abrir menu de navegação">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <nav aria-label="Navegação mobile">
        {itensNavegacao.map((item) => <a href={item.href}>{item.texto}</a>)}
        <a class="cabecalho__cta-mobile" href={empresa.linkWhatsappOrcamento} target="_blank" rel="noopener noreferrer">
          Solicitar orçamento
        </a>
      </nav>
    </details>
  </div>
</header>

<style>
  .cabecalho {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--cor-azul-900);
    color: var(--cor-branco);
    border-bottom: 1px solid rgb(255 255 255 / 12%);
  }

  .cabecalho__conteudo {
    width: calc(100% - 32px);
    max-width: var(--largura-conteudo);
    min-height: var(--altura-cabecalho);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .cabecalho__marca {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    min-height: 52px;
  }

  .cabecalho__marca img {
    width: clamp(150px, 18vw, 218px);
    height: auto;
  }

  .cabecalho__navegacao {
    display: none;
    align-items: center;
    gap: 28px;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .cabecalho__navegacao a {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    color: rgb(255 255 255 / 84%);
    transition: color 180ms ease;
  }

  .cabecalho__navegacao a:hover {
    color: var(--cor-branco);
  }

  .cabecalho__cta,
  .cabecalho__cta-mobile {
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(255 255 255 / 48%);
    border-radius: 8px;
    color: var(--cor-branco);
    font-weight: 700;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .cabecalho__cta {
    display: none;
    padding: 0 18px;
  }

  .cabecalho__cta:hover,
  .cabecalho__cta-mobile:hover {
    background: rgb(255 255 255 / 10%);
    border-color: rgb(255 255 255 / 72%);
    transform: translateY(-1px);
  }

  .cabecalho__menu-mobile {
    position: static;
  }

  .cabecalho__menu-mobile summary {
    position: relative;
    width: 48px;
    height: 48px;
    display: grid;
    place-content: center;
    gap: 5px;
    border: 1px solid rgb(255 255 255 / 28%);
    border-radius: 8px;
    cursor: pointer;
    list-style: none;
  }

  .cabecalho__menu-mobile summary::-webkit-details-marker {
    display: none;
  }

  .cabecalho__menu-mobile summary span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 2px;
    display: block;
    border-radius: 999px;
    background: var(--cor-branco);
    transform: translate(-50%, -50%);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .cabecalho__menu-mobile summary span:nth-child(1) {
    transform: translate(-50%, calc(-50% - 7px));
  }

  .cabecalho__menu-mobile summary span:nth-child(3) {
    transform: translate(-50%, calc(-50% + 7px));
  }

  .cabecalho__menu-mobile[open] summary span:nth-child(1) {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .cabecalho__menu-mobile[open] summary span:nth-child(2) {
    opacity: 0;
  }

  .cabecalho__menu-mobile[open] summary span:nth-child(3) {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .cabecalho__menu-mobile nav {
    position: fixed;
    top: var(--altura-cabecalho);
    right: 0;
    bottom: 0;
    left: 0;
    width: 100%;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 14px;
    padding: 32px 24px;
    border-top: 1px solid rgb(255 255 255 / 14%);
    border-radius: 0;
    background: var(--cor-azul-900);
    box-shadow: 0 18px 50px rgb(0 0 0 / 28%);
  }

  .cabecalho__menu-mobile nav a {
    width: min(100%, 320px);
    min-height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    padding: 0 18px;
    font-size: 1.15rem;
    font-weight: 800;
    color: rgb(255 255 255 / 90%);
    text-align: center;
  }

  .cabecalho__menu-mobile nav a:hover {
    background: rgb(255 255 255 / 8%);
    color: var(--cor-branco);
  }

  .cabecalho__cta-mobile {
    margin-top: 12px;
    display: flex;
    border-color: rgb(255 255 255 / 44%);
  }

  @media (min-width: 920px) {
    .cabecalho__navegacao,
    .cabecalho__cta {
      display: inline-flex;
    }

    .cabecalho__menu-mobile {
      display: none;
    }
  }
</style>
