---
import { Image } from "astro:assets";
import imagemSalaPainel from "../assets/imagens/sala-painel-sob-medida-joinville.jpeg";
import imagemDormitorioBancada from "../assets/imagens/dormitorio-bancada-espelho-sob-medida-joinville.jpeg";
import imagemCabeceiraDormitorio from "../assets/imagens/cabeceira-dormitorio-sob-medida-joinville.jpeg";
import imagemArmarioEspelhado from "../assets/imagens/armario-espelhado-prateleiras-sob-medida-joinville.jpeg";
import CarrosselVideosProjetos from "@componentes/CarrosselVideosProjetos.astro";
import { empresa } from "@dados/empresa";
import { projetos } from "@dados/projetos";

const imagensProjetos = {
  "sala-painel": imagemSalaPainel,
  "dormitorio-bancada": imagemDormitorioBancada,
  "cabeceira-dormitorio": imagemCabeceiraDormitorio,
  "armario-espelhado": imagemArmarioEspelhado,
} as const;
---

<section class="projetos" id="projetos" aria-labelledby="titulo-projetos">
  <div class="projetos__conteudo">
    <div class="projetos__cabecalho">
      <div>
        <p class="projetos__chamada">Projetos reais</p>
        <h2 id="titulo-projetos">Moveis sob medida feitos para a rotina de cada casa.</h2>
      </div>

      <div class="projetos__introducao">
        <p>
          Veja detalhes de ambientes executados pela Kazanova Sob Medida em salas e dormitorios,
          com foco em aproveitamento de espaco, acabamento e uso diario.
        </p>
        <a href={empresa.linkWhatsappOrcamento} target="_blank" rel="noopener noreferrer">Solicitar orcamento</a>
      </div>
    </div>

    <div class="projetos__grade" aria-label="Galeria de projetos da Kazanova Sob Medida">
      {
        projetos.map((projeto, indice) => (
          <article class:list={["projetos__cartao", indice === 0 && "projetos__cartao--destaque"]}>
            <div class="projetos__imagem">
              <Image
                src={imagensProjetos[projeto.imagem]}
                alt={`${projeto.nome} feito pela Kazanova Sob Medida em Joinville`}
                widths={[360, 520, 720, 960, 1200]}
                sizes={indice === 0 ? "(min-width: 980px) 48vw, 100vw" : "(min-width: 980px) 24vw, 100vw"}
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="projetos__informacoes">
              <p>{projeto.ambiente}</p>
              <h3>{projeto.nome}</h3>
              <span>{projeto.resumo}</span>
              <ul aria-label={`Detalhes do projeto ${projeto.nome}`}>
                {projeto.detalhes.map((detalhe) => <li>{detalhe}</li>)}
              </ul>
            </div>
          </article>
        ))
      }
    </div>

    <CarrosselVideosProjetos />
  </div>
</section>

<style>
  .projetos {
    background: var(--cor-neutro-100);
    scroll-margin-top: var(--altura-cabecalho);
  }

  .projetos__conteudo {
    width: min(calc(100% - 32px), var(--largura-conteudo));
    margin: 0 auto;
    padding: 72px 0;
  }

  .projetos__cabecalho {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
    margin-bottom: 32px;
  }

  .projetos__chamada {
    margin: 0 0 12px;
    color: var(--cor-madeira-600);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .projetos h2 {
    max-width: 13ch;
    margin: 0;
    color: var(--cor-azul-900);
    font-family: var(--fonte-titulo);
    font-size: clamp(2rem, 9vw, 3.5rem);
    font-weight: 700;
    line-height: 1.04;
    overflow-wrap: break-word;
  }

  .projetos__introducao {
    max-width: 560px;
    align-self: end;
  }

  .projetos__introducao p {
    margin: 0;
    color: var(--cor-neutro-700);
    line-height: 1.65;
  }

  .projetos__introducao a {
    min-height: 50px;
    width: fit-content;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 20px;
    border-radius: 8px;
    padding: 0 22px;
    background: var(--cor-azul-900);
    color: var(--cor-branco);
    font-weight: 800;
    transition:
      background 180ms ease,
      transform 180ms ease;
  }

  .projetos__introducao a:hover {
    background: var(--cor-azul-800);
    transform: translateY(-1px);
  }

  .projetos__grade {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .projetos__cartao {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: clamp(320px, 92vw, 430px);
    display: flex;
    align-items: flex-end;
    border-radius: var(--raio-card);
    background: var(--cor-azul-900);
    box-shadow: 0 18px 54px rgb(11 49 90 / 10%);
  }

  .projetos__cartao::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgb(11 49 90 / 0%) 22%, rgb(11 49 90 / 86%) 100%),
      linear-gradient(90deg, rgb(11 49 90 / 54%) 0%, rgb(11 49 90 / 0%) 58%);
    pointer-events: none;
  }

  .projetos__imagem {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: var(--cor-neutro-200);
  }

  .projetos__imagem :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 240ms ease;
  }

  .projetos__cartao:hover .projetos__imagem :global(img) {
    transform: scale(1.025);
  }

  .projetos__informacoes {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 18px;
  }

  .projetos__informacoes p {
    margin: 0 0 8px;
    color: rgb(255 255 255 / 82%);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .projetos h3 {
    margin: 0;
    color: var(--cor-branco);
    font-size: clamp(1.18rem, 4vw, 1.45rem);
    line-height: 1.16;
  }

  .projetos__informacoes span {
    display: block;
    margin-top: 10px;
    color: rgb(255 255 255 / 86%);
    line-height: 1.55;
  }

  .projetos__informacoes ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 16px 0 0;
    padding: 0;
    list-style: none;
  }

  .projetos__informacoes li {
    border: 1px solid rgb(255 255 255 / 22%);
    border-radius: 999px;
    padding: 7px 10px;
    color: var(--cor-branco);
    font-size: 0.86rem;
    font-weight: 800;
    line-height: 1;
    background: rgb(255 255 255 / 10%);
  }

  @media (max-width: 520px) {
    .projetos__conteudo {
      padding: 56px 0;
    }

    .projetos__introducao a {
      width: 100%;
    }
  }

  @media (min-width: 720px) {
    .projetos__grade {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 980px) {
    .projetos__conteudo {
      padding: 64px 0;
    }

    .projetos__cabecalho {
      grid-template-columns: minmax(0, 0.95fr) minmax(360px, 0.7fr);
      align-items: end;
      gap: 48px;
      margin-bottom: 36px;
    }

    .projetos h2 {
      max-width: 22ch;
      font-size: clamp(2.75rem, 3.2vw, 3.55rem);
      line-height: 1;
    }

    .projetos__grade {
      height: clamp(420px, 48vh, 560px);
      grid-template-columns: minmax(0, 1.16fr) minmax(0, 0.84fr);
      grid-template-rows: repeat(3, minmax(0, 1fr));
    }

    .projetos__cartao {
      min-height: 0;
    }

    .projetos__cartao--destaque {
      grid-row: 1 / span 3;
    }

    .projetos__cartao:not(.projetos__cartao--destaque) .projetos__informacoes span,
    .projetos__cartao:not(.projetos__cartao--destaque) .projetos__informacoes ul {
      display: none;
    }

    .projetos__cartao--destaque .projetos__informacoes {
      padding: 22px;
    }
  }

  @media (min-width: 980px) and (max-height: 820px) {
    .projetos__conteudo {
      padding: 44px 0;
    }

    .projetos__cabecalho {
      margin-bottom: 24px;
    }

    .projetos h2 {
      font-size: clamp(2.45rem, 3vw, 3.15rem);
    }

    .projetos__introducao p {
      line-height: 1.5;
    }

    .projetos__cartao--destaque .projetos__imagem {
      min-height: 0;
    }

    .projetos__informacoes {
      padding: 16px;
    }
  }
</style>
