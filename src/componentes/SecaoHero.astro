---
import { Image } from "astro:assets";
import imagemHero from "../assets/imagens/sala-painel-sob-medida-joinville.jpeg";
import { empresa } from "@dados/empresa";
---

<section class="hero" id="inicio" aria-labelledby="titulo-hero">
  <div class="hero__conteudo">
    <div class="hero__texto">
      <p class="hero__chamada">Móveis sob medida em {empresa.cidade}, {empresa.estadoSigla}</p>
      <h1 id="titulo-hero">Móveis sob medida para transformar seu ambiente.</h1>
      <p class="hero__descricao">
        Projetamos e fabricamos móveis personalizados com acabamento cuidadoso,
        funcionalidade e aproveitamento inteligente de espaço para Joinville e região.
      </p>

      <div class="hero__acoes" aria-label="Ações principais">
        <a class="hero__botao hero__botao--principal" href={empresa.linkWhatsappOrcamento} target="_blank" rel="noopener noreferrer">
          Solicitar orçamento
        </a>
        <a class="hero__botao hero__botao--secundario" href="#projetos">Ver projetos</a>
      </div>

      <dl class="hero__provas" aria-label="Diferenciais da Kazanova Sob Medida">
        <div>
          <dt>{empresa.anosExperiencia} anos</dt>
          <dd>de experiência</dd>
        </div>
        <div>
          <dt>Fabricação</dt>
          <dd>própria</dd>
        </div>
        <div>
          <dt>{empresa.cidade}</dt>
          <dd>e região</dd>
        </div>
      </dl>
    </div>

    <div class="hero__midia">
      <Image
        src={imagemHero}
        alt="Sala com painel, rack e prateleiras de madeira feitos sob medida pela Kazanova em Joinville"
        widths={[520, 720, 960, 1200]}
        sizes="(min-width: 980px) 50vw, 100vw"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100dvh - var(--altura-cabecalho));
    background: var(--cor-neutro-100);
  }

  .hero__conteudo {
    width: 100%;
    min-height: calc(100dvh - var(--altura-cabecalho));
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    padding: 14px 16px 20px;
  }

  .hero__texto {
    width: min(100%, 620px);
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    position: relative;
    z-index: 2;
  }

  .hero__chamada {
    margin: 0 0 14px;
    color: var(--cor-azul-800);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: 9.6ch;
    margin: 0;
    color: var(--cor-azul-900);
    font-family: var(--fonte-titulo);
    font-size: clamp(2.15rem, 8.9vw, 2.55rem);
    font-weight: 700;
    line-height: 1;
    overflow-wrap: break-word;
  }

  .hero__descricao {
    max-width: 560px;
    margin: 16px 0 0;
    color: var(--cor-neutro-700);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.6;
  }

  .hero__acoes {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  .hero__botao {
    min-height: 50px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    padding: 0 22px;
    font-weight: 800;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .hero__botao:hover {
    transform: translateY(-1px);
  }

  .hero__botao--principal {
    background: var(--cor-azul-900);
    color: var(--cor-branco);
  }

  .hero__botao--principal:hover {
    background: var(--cor-azul-800);
  }

  .hero__botao--secundario {
    border: 1px solid var(--cor-azul-900);
    color: var(--cor-azul-900);
    background: rgb(255 255 255 / 82%);
  }

  .hero__botao--secundario:hover {
    background: var(--cor-branco);
    border-color: var(--cor-madeira-600);
  }

  .hero__provas {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin: 22px 0 0;
  }

  .hero__provas div {
    border-left: 3px solid var(--cor-madeira-500);
    padding-left: 12px;
  }

  .hero__provas dt {
    color: var(--cor-azul-900);
    font-weight: 900;
    line-height: 1.2;
  }

  .hero__provas dd {
    margin: 4px 0 0;
    color: var(--cor-neutro-700);
    font-size: 0.92rem;
  }

  .hero__midia {
    order: -1;
    width: min(100%, 560px);
    min-height: 0;
    aspect-ratio: 16 / 8.4;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    border-radius: var(--raio-card);
    box-shadow: var(--sombra-suave);
  }

  .hero__midia :global(img) {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
  }

  @media (max-width: 520px) {
    .hero__acoes {
      flex-direction: column;
    }

    .hero__botao {
      width: 100%;
    }

    .hero__provas {
      gap: 8px;
    }

    .hero__provas div {
      padding-left: 8px;
    }

    .hero__provas dt {
      font-size: 0.9rem;
    }

    .hero__provas dd {
      font-size: 0.82rem;
    }
  }

  @media (min-width: 760px) {
    .hero__conteudo {
      padding: 28px 32px 44px;
    }

    .hero__texto {
      width: min(100%, 680px);
    }

    .hero h1 {
      max-width: 12ch;
      font-size: 4rem;
    }
  }

  @media (min-width: 980px) {
    .hero__conteudo {
      height: calc(100dvh - var(--altura-cabecalho));
      min-height: 660px;
      grid-template-columns: minmax(480px, 0.92fr) minmax(0, 1.08fr);
      gap: 0;
      padding: 0;
      overflow: hidden;
    }

    .hero__texto {
      width: min(calc(100% - 72px), 650px);
      padding: clamp(36px, 5vh, 64px) 0;
      justify-content: center;
    }

    .hero h1 {
      max-width: 12ch;
      font-size: clamp(4.1rem, 5.1vw, 5.65rem);
      line-height: 0.98;
    }

    .hero__midia {
      order: 0;
      width: 100%;
      height: 100%;
      aspect-ratio: auto;
      margin: 0;
      border-radius: 0;
      box-shadow: none;
    }

    .hero__midia::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(90deg, var(--cor-neutro-100) 0%, rgb(244 245 247 / 72%) 11%, rgb(244 245 247 / 0%) 34%);
      pointer-events: none;
    }

    .hero__midia :global(img) {
      height: 100%;
      min-height: 0;
      object-position: center;
    }
  }

  @media (min-width: 980px) and (max-height: 820px) {
    .hero__conteudo {
      min-height: 600px;
    }

    .hero h1 {
      font-size: clamp(3.75rem, 4.5vw, 4.8rem);
    }

    .hero__descricao {
      margin-top: 16px;
      line-height: 1.6;
    }

    .hero__acoes {
      margin-top: 22px;
    }

    .hero__provas {
      margin-top: 24px;
    }
  }
</style>
